# === 应用配置 ===

# 应用名称
APP_NAME="Agent CA API"

# 应用版本
APP_VERSION="1.0.0"

# 调试模式（开发环境建议为 true）
DEBUG=true

# API 文档访问（开发环境建议为 true）
DOCS_ENABLED=true

# Agent 证书 CN 所使用的域名后缀（不需要前导点）
AGENT_CN_DOMAIN_SUFFIX=acps.pub

# === 服务器配置 ===
# 服务器主机地址
HOST=0.0.0.0

# 服务器端口
PORT=8003

# === 数据库配置 ===
# PostgreSQL 数据库连接 URL（请根据实际连接信息进行修改）
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/agent_ca

# === 安全配置 ===
# JWT 密钥（请使用强密码，可以用 openssl rand -hex 32 生成）
SECRET_KEY=your_secret_key_here

# JWT 算法
ALGORITHM=HS256

# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === 日志配置 ===
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# 日志文件路径
LOG_FILE=logs/app.log

# === CORS 配置 ===
# 允许的域名（开发环境可以设置为 "*"）
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# === 外部服务集成配置 ===

# Mock 模式配置 (开发/测试环境使用)
# 启用后将使用假数据而不是真实的外部服务
AGENT_REGISTRY_MOCK=false
HTTP01_VALIDATION_MOCK=false
# 通用Mock开关，覆盖所有外部服务
EXTERNAL_SERVICES_MOCK=false

# Agent 注册服务配置
AGENT_REGISTRY_URL=http://localhost:8001
AGENT_REGISTRY_TIMEOUT=10
AGENT_REGISTRY_SERVICE_TOKEN=your-agent-registry-service-token

# SSO 服务配置
SSO_SERVICE_URL=http://localhost:8003
SSO_SERVICE_TIMEOUT=10

# 外部服务重试配置
EXTERNAL_SERVICE_MAX_RETRIES=3
EXTERNAL_SERVICE_RETRY_DELAYS=1,2,4

# HTTP-01 验证配置
HTTP01_VALIDATION_TIMEOUT=30
HTTP01_VALIDATION_RETRIES=2

# === Redis 配置（如果使用缓存）===
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# === 配置说明 ===
#
# AGENT_REGISTRY_URL: Agent注册服务的基础URL
# AGENT_REGISTRY_SERVICE_TOKEN: 用于调用Agent注册服务API的服务令牌
# SSO_SERVICE_URL: SSO服务的基础URL（用于管理API认证）
# EXTERNAL_SERVICE_MAX_RETRIES: 外部服务调用最大重试次数
# EXTERNAL_SERVICE_RETRY_DELAYS: 重试间隔时间（秒），逗号分隔
# HTTP01_VALIDATION_TIMEOUT: HTTP-01验证请求超时时间（秒）
# HTTP01_VALIDATION_RETRIES: HTTP-01验证重试次数

# === ATR 管理功能安全配置 ===
# ATR 管理功能 IP 限制配置
# 允许访问 ATR 管理功能的 IP 地址列表，逗号分隔
# 支持单个IP和CIDR网段，例如: 192.168.1.100,10.0.0.0/8,172.16.0.0/16
# 默认仅允许本地访问，生产环境请根据实际需求配置
ATR_MGMT_ALLOW_IP_LIST=127.0.0.1,::1

# ACME 配置
ACME_DIRECTORY_URL=http://localhost:8003/acme
ACME_TERMS_OF_SERVICE=https://agent-ca.example.com/terms
ACME_WEBSITE=https://agent-ca.example.com
ACME_CAA_IDENTITIES=agent-ca.example.com