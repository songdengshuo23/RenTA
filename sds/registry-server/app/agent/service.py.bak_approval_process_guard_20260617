def _agent_timestamp_sort_value(agent: Agent) -> str:
    timestamp = (
        agent.processed_at
        or agent.submitted_at
        or agent.updated_at
        or agent.created_at
    )
    return timestamp.isoformat() if timestamp else ""


def _agent_version_sort_key(agent: Agent) -> Tuple[Tuple[int, ...], str, str, str]:
    """Sort same-name Agents by semantic-ish version first, then review time."""
    version_text = str(agent.version or "")
    numeric_version = tuple(int(part) for part in re.findall(r"\d+", version_text))
    return (numeric_version, version_text, _agent_timestamp_sort_value(agent), str(agent.id))


def _is_newer_agent_version(candidate: Agent, current: Agent) -> bool:
    return _agent_version_sort_key(candidate) > _agent_version_sort_key(current)


def _dedupe_agents_by_latest_name(agents: List[Agent]) -> List[Agent]:
    latest_by_name: Dict[str, Agent] = {}
    for agent in agents:
        current = latest_by_name.get(agent.name)
        if current is None or _is_newer_agent_version(agent, current):
            latest_by_name[agent.name] = agent
    return sorted(
        latest_by_name.values(),
        key=_agent_timestamp_sort_value,
        reverse=True,
    )


def retire_older_same_name_agents(db: Session, agent: Agent) -> List[Agent]:
    """Keep only the latest approved active Agent for a name visible/callable."""
    if (
        agent.approval_status != ApprovalStatus.APPROVED
        or not agent.is_active
        or agent.is_deleted
        or agent.is_disabled
    ):
        return []

    candidate_agents = db.query(Agent).filter(Agent.name == agent.name).all()
    active_same_name_agents = [
        candidate
        for candidate in candidate_agents
        if candidate.id != agent.id
        and candidate.name == agent.name
        and candidate.approval_status == ApprovalStatus.APPROVED
        and candidate.is_active
        and not candidate.is_deleted
        and not candidate.is_disabled
    ]
    if not active_same_name_agents:
        return []

    newest_agent = agent
    for candidate in active_same_name_agents:
        if _is_newer_agent_version(candidate, newest_agent):
            newest_agent = candidate

    now = get_beijing_time()
    retired: List[Agent] = []
    for old_agent in [agent, *active_same_name_agents]:
        if old_agent.id == newest_agent.id:
            continue
        old_agent.is_active = False
        old_agent.is_deleted = True
        old_agent.deleted_at = now
        old_agent.deleted_reason = (
            f"Superseded by newer version {newest_agent.version} of {newest_agent.name}"
        )
        old_agent.updated_at = now
        update_agent_acs_data(old_agent, db)
        db.add(old_agent)
        retired.append(old_agent)
    return retired


def create_agent_response(agent: Agent) -> AgentResponse:
    """将 Agent ORM 对象转换为 AgentResponse"""
    if not agent:
        return None

    # 使用 model_validate 替代 from_orm
    return AgentResponse.model_validate(agent)


def create_agent_detail_response(agent: Agent) -> AgentDetailResponse:
    """将 Agent ORM 对象转换为包含完整用户对象的 AgentDetailResponse"""
    if not agent:
        return None

    # 先创建基本 AgentResponse
    response = AgentResponse.model_validate(agent)

    # 创建详情响应对象并继承基本响应的所有字段
    detail_response = AgentDetailResponse(**response.model_dump())

    # 添加完整用户对象
    if agent.created_by:
        detail_response.created_by = UserResponse.model_validate(agent.created_by)

    if agent.processed_by:
        detail_response.processed_by = UserResponse.model_validate(agent.processed_by)

    return detail_response


