def _agent_aic_for_certificate_sync(agent: Agent, payload: Dict[str, Any]) -> Optional[str]:
    identity = payload.get("identity") if isinstance(payload.get("identity"), dict) else {}
    acs = agent.acs if isinstance(agent.acs, dict) else {}
    return agent.aic or identity.get("aic") or acs.get("aic")


def _sync_passport_identity_from_agent(payload: Dict[str, Any], agent: Agent) -> None:
    identity = payload.setdefault("identity", {})
    if agent.aic:
        identity["aic"] = agent.aic
    identity["agentId"] = str(agent.id)
    identity["name"] = agent.name
    identity["version"] = agent.version

    acp = payload.setdefault("acp", {})
    acp["acsHash"] = agent.acs_hash
    acp["acsVersion"] = agent.acs_version
    if isinstance(agent.acs, dict) and agent.acs.get("lastModifiedTime"):
        acp["lastModifiedTime"] = agent.acs.get("lastModifiedTime")


def _sync_review_snapshot_from_agent(
    review_record: AgentSupervisorReview, agent: Agent
) -> None:
    review_record.agent_acs_hash = agent.acs_hash or ""
    review_record.agent_acs_version = agent.acs_version

    passport_draft = copy.deepcopy(review_record.passport_draft or {})
    _sync_passport_identity_from_agent(passport_draft, agent)
    review_record.passport_draft = passport_draft

    review_result = copy.deepcopy(review_record.review_result or {})
    if isinstance(review_result.get("passportDraft"), dict):
        _sync_passport_identity_from_agent(review_result["passportDraft"], agent)
    review_record.review_result = review_result
    review_record.updated_at = get_beijing_time()


def _passport_certificate_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    acp = payload.setdefault("acp", {})
    certificate = acp.setdefault("certificate", {})
    certificate.setdefault("status", "NOT_ISSUED")
    certificate.setdefault("issuer", None)
    certificate.setdefault("serialNumber", None)
    certificate.setdefault("notBefore", None)
    certificate.setdefault("notAfter", None)
    certificate.setdefault("mtlsRequired", True)
    return certificate


def _passport_certificate_sync_is_current(
    certificate: Optional[Dict[str, Any]],
    passport_status: str,
    agent_aic: Optional[str] = None,
) -> bool:
    if not isinstance(certificate, dict):
        return False
    certificate_aic = certificate.get("aic")
    if passport_status == "VALID" and agent_aic and certificate_aic != agent_aic:
        return False
    return (
        certificate.get("passportStatus") == passport_status
        and bool(certificate.get("lastSyncedAt"))
    )


def _extract_ca_subject_components(payload: Dict[str, Any]) -> Dict[str, str]:
    identity = payload.get("identity") if isinstance(payload.get("identity"), dict) else {}
    provider = identity.get("provider") if isinstance(identity.get("provider"), dict) else {}
    mapping = {
        "O": provider.get("organization"),
        "OU": provider.get("department"),
        "C": provider.get("countryCode"),
    }
    return {key: value for key, value in mapping.items() if value}


def _extract_ca_endpoint_urls(payload: Dict[str, Any]) -> List[str]:
    acp = payload.get("acp") if isinstance(payload.get("acp"), dict) else {}
    endpoints = acp.get("endpoints") if isinstance(acp.get("endpoints"), list) else []
    urls: List[str] = []
    for endpoint in endpoints:
        if isinstance(endpoint, dict) and endpoint.get("url"):
            urls.append(str(endpoint["url"]))
    return urls


def _get_ca_sync_field(data: Dict[str, Any], *names: str) -> Any:
    for name in names:
        if name in data:
            return data[name]
    return None


def _parse_ca_datetime(value: Optional[str]) -> Optional[datetime]:
    if not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None


def _mock_ca_certificate_sync(agent: Agent, passport: AgentPassport) -> Dict[str, Any]:
    status_value = passport.status
    certificate_status = "NOT_ISSUED"
    action = "deferred"
    serial_number = None
    issuer = None
    if status_value == "VALID":
        certificate_status = "VALID"
        action = "issued"
        serial_number = f"MOCK-{passport.review_id}"
        issuer = "ACPS Mock CA"
    elif status_value == "SUSPENDED":
        certificate_status = "REVOKED"
        action = "revoked"

    return {
        "aic": _agent_aic_for_certificate_sync(agent, passport.passport_payload or {}),
        "passportStatus": status_value,
        "action": action,
        "certificateStatus": certificate_status,
        "issuer": issuer,
        "serialNumber": serial_number,
        "notBefore": passport.issued_at.isoformat() if passport.issued_at else None,
        "notAfter": None,
        "version": None,
        "revokedCertCount": 0,
        "revocationReason": None,
        "mtlsRequired": True,
        "renewalWindowDays": settings.PASSPORT_CERT_RENEWAL_WINDOW_DAYS,
        "daysUntilExpiry": None,
        "renewalDue": False,
        "nextReviewAfter": None,
        "rotationAudit": [],
        "runtimeAlerts": [],
    }


def sync_passport_certificate_with_ca(
    agent: Agent, passport: AgentPassport
) -> Dict[str, Any]:
    payload = passport.passport_payload or {}
    certificate = _passport_certificate_payload(payload)
    aic_value = _agent_aic_for_certificate_sync(agent, payload)
    mtls_required = bool(certificate.get("mtlsRequired", True))

    if not aic_value:
        return {
            "aic": None,
            "passportStatus": passport.status,
            "action": "skipped",
            "certificateStatus": "NOT_ISSUED",
            "issuer": None,
            "serialNumber": None,
            "notBefore": None,
            "notAfter": None,
            "version": None,
            "revokedCertCount": 0,
            "revocationReason": "missing_aic",
            "mtlsRequired": mtls_required,
        }

    if settings.CA_SERVER_MOCK:
        return _mock_ca_certificate_sync(agent, passport)

    ca_server_url = getattr(settings, "CA_SERVER_BASE_URL", None)
    if not ca_server_url:
        raise AgentException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            error_name=AgentError.REMOTE_CERT_SYNC_FAILED,
            error_msg="CA Server URL is not configured",
            input_params={"agent_aic": aic_value, "error_type": "config_error"},
        )

    request_body = {
        "aic": aic_value,
        "passportStatus": passport.status,
        "mtlsRequired": mtls_required,
        "subjectComponents": _extract_ca_subject_components(payload),
        "endpointUrls": _extract_ca_endpoint_urls(payload),
        "validityDays": settings.PASSPORT_CERT_VALIDITY_DAYS,
        "renewalWindowDays": settings.PASSPORT_CERT_RENEWAL_WINDOW_DAYS,
    }
    sync_url = f"{ca_server_url.rstrip('/')}/ca/passport-sync"

    try:
        response = requests.post(
            sync_url,
            json=request_body,
            headers={
                "Content-Type": "application/json",
                "User-Agent": "ACPS-Registry-Server/1.0",
                **build_bearer_auth_header(settings.CA_SERVER_SERVICE_TOKEN),
            },
            timeout=30,
        )
        if response.status_code != 200:
            raise AgentException(
                status_code=status.HTTP_502_BAD_GATEWAY,
                error_name=AgentError.REMOTE_CERT_SYNC_FAILED,
                error_msg="CA Server returned error when syncing passport certificate",
                input_params={
                    "agent_aic": aic_value,
                    "status_code": response.status_code,
                    "response": response.text,
                },
            )
        return response.json()
    except AgentException:
        raise
    except requests.exceptions.RequestException as exc:
        raise AgentException(
            status_code=status.HTTP_502_BAD_GATEWAY,
            error_name=AgentError.REMOTE_CERT_SYNC_FAILED,
            error_msg="Network error when syncing passport certificate with CA Server",
            input_params={"agent_aic": aic_value, "error": str(exc)},
        ) from exc


def _apply_certificate_sync_result(
    passport: AgentPassport, sync_result: Dict[str, Any]
) -> None:
    payload = passport.passport_payload or {}
    certificate = _passport_certificate_payload(payload)
    mtls_required = _get_ca_sync_field(sync_result, "mtlsRequired", "mtls_required")
    if mtls_required is None:
        mtls_required = certificate.get("mtlsRequired", True)
    certificate.update(
        {
            "status": _get_ca_sync_field(
                sync_result, "certificateStatus", "certificate_status"
            )
            or certificate.get("status"),
            "aic": _get_ca_sync_field(sync_result, "aic") or certificate.get("aic"),
            "issuer": _get_ca_sync_field(sync_result, "issuer"),
            "serialNumber": _get_ca_sync_field(
                sync_result, "serialNumber", "serial_number"
            ),
            "notBefore": _get_ca_sync_field(sync_result, "notBefore", "not_before"),
            "notAfter": _get_ca_sync_field(sync_result, "notAfter", "not_after"),
            "version": _get_ca_sync_field(sync_result, "version"),
            "revokedCertCount": _get_ca_sync_field(
                sync_result, "revokedCertCount", "revoked_cert_count"
            )
            or 0,
            "revocationReason": _get_ca_sync_field(
                sync_result, "revocationReason", "revocation_reason"
            ),
            "mtlsRequired": bool(mtls_required),
            "syncAction": _get_ca_sync_field(sync_result, "action"),
            "renewalWindowDays": _get_ca_sync_field(
                sync_result, "renewalWindowDays", "renewal_window_days"
            )
            or settings.PASSPORT_CERT_RENEWAL_WINDOW_DAYS,
            "daysUntilExpiry": _get_ca_sync_field(
                sync_result, "daysUntilExpiry", "days_until_expiry"
            ),
            "renewalDue": bool(
                _get_ca_sync_field(sync_result, "renewalDue", "renewal_due")
            ),
            "nextReviewAfter": _get_ca_sync_field(
                sync_result, "nextReviewAfter", "next_review_after"
            ),
            "rotationAudit": _get_ca_sync_field(
                sync_result, "rotationAudit", "rotation_audit"
            )
            or [],
            "runtimeAlerts": _get_ca_sync_field(
                sync_result, "runtimeAlerts", "runtime_alerts"
            )
            or [],
            "passportStatus": passport.status,
            "lastSyncedAt": get_beijing_time().isoformat(),
            "source": "ca-server",
        }
    )
    passport.passport_payload = payload

    not_before = _parse_ca_datetime(certificate.get("notBefore"))
    not_after = _parse_ca_datetime(certificate.get("notAfter"))
    if passport.status == "VALID" and not_before:
        passport.issued_at = not_before
    if not_after:
        passport.expires_at = not_after
    next_review_after = _parse_ca_datetime(certificate.get("nextReviewAfter"))
    if next_review_after:
        passport.review_after = next_review_after
    elif not_after and passport.status == "VALID":
        passport.review_after = not_after - timedelta(
            days=settings.PASSPORT_CERT_RENEWAL_WINDOW_DAYS
        )
    elif passport.status == "DRAFT":
        passport.review_after = get_beijing_time() + timedelta(
            days=settings.PASSPORT_DRAFT_REVIEW_AFTER_DAYS
        )


def _apply_passport_from_review(
    passport: AgentPassport, agent: Agent, review_record: AgentSupervisorReview
) -> AgentPassport:
    now = get_beijing_time()
    payload = copy.deepcopy(review_record.passport_draft or {})
    status = _passport_status_for_review(review_record)
    payload["status"] = status
    _sync_passport_identity_from_agent(payload, agent)
    _passport_certificate_payload(payload)
    passport.passport_id = _passport_id_for_review(review_record)
    passport.agent_id = agent.id
    passport.review_id = review_record.review_id
    passport.status = status
    passport.passport_version = str(payload.get("passportVersion", "1.0"))
    passport.acs_hash = agent.acs_hash or ""
    passport.acs_version = agent.acs_version
    passport.decision = review_record.decision
    passport.risk_level = review_record.risk_level
    passport.permission_tier = review_record.permission_tier
    passport.passport_payload = payload
    passport.issued_at = passport.issued_at or now if status == "VALID" else None
    passport.expires_at = None
    passport.review_after = None
    passport.updated_at = now
    return passport


