def _as_dict(value: Any) -> Dict[str, Any]:
    return value if isinstance(value, dict) else {}


def _first_present(*values: Any) -> Any:
    for value in values:
        if value is not None:
            return value
    return None


def _as_bool(value: Any) -> Optional[bool]:
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"true", "1", "yes", "y", "on"}:
            return True
        if lowered in {"false", "0", "no", "n", "off"}:
            return False
    return None


def _as_float(value: Any) -> Optional[float]:
    if value is None or isinstance(value, bool):
        return None
    try:
        return float(value)
    except (TypeError, ValueError):
        return None


def _agent_owner_user_id(agent: Agent, payload: Dict[str, Any]) -> str:
    identity = _as_dict(payload.get("identity"))
    acs = _as_dict(getattr(agent, "acs", None))
    return str(
        _first_present(
            getattr(agent, "created_by_id", None),
            identity.get("ownerUserId"),
            identity.get("entityUserId"),
            acs.get("ownerUserId"),
            acs.get("entityUserId"),
            payload.get("ownerUserId"),
            payload.get("entityUserId"),
        )
        or ""
    )


def _same_requester(owner_user_id: str, requester_user_id: Optional[str]) -> bool:
    return bool(owner_user_id and requester_user_id and owner_user_id == str(requester_user_id))


def _passport_visibility_view(
    agent: Agent, payload: Dict[str, Any], requester_user_id: Optional[str] = None
) -> Dict[str, Any]:
    hints = _as_dict(payload.get("orchestratorHints"))
    access = _as_dict(payload.get("access"))
    visibility_payload = payload.get("visibility")
    visibility_obj = _as_dict(visibility_payload)
    owner_user_id = _agent_owner_user_id(agent, payload)
    visibility = str(
        _first_present(
            visibility_obj.get("scope"),
            visibility_obj.get("visibility"),
            visibility_payload if isinstance(visibility_payload, str) else None,
            hints.get("visibility"),
            access.get("visibility"),
            "public",
        )
        or "public"
    ).lower()

    share_flags = [
        hints.get("callableByOthers"),
        hints.get("shareEnabled"),
        hints.get("publicCallable"),
        hints.get("allowExternalInvocation"),
        access.get("callableByOthers"),
        access.get("shareEnabled"),
        access.get("publicCallable"),
        access.get("allowExternalInvocation"),
        visibility_obj.get("callableByOthers"),
    ]
    explicit_share_disabled = any(_as_bool(value) is False for value in share_flags)
    owner_request = _same_requester(owner_user_id, requester_user_id)
    reasons: List[str] = []
    if visibility in {"private", "owner", "owner_only", "local"} and not owner_request:
        reasons.append("agent_private_to_owner")
    if explicit_share_disabled and not owner_request:
        reasons.append("agent_sharing_disabled")

    return {
        "visibility": visibility,
        "ownerUserId": owner_user_id,
        "requesterIsOwner": owner_request,
        "shareEnabled": not explicit_share_disabled,
        "reasons": reasons,
    }


def _passport_runtime_view(payload: Dict[str, Any]) -> Dict[str, Any]:
    hints = _as_dict(payload.get("orchestratorHints"))
    runtime_raw = _first_present(
        payload.get("runtimeStatus"),
        payload.get("runtime"),
        payload.get("availability"),
        payload.get("health"),
        hints.get("runtimeStatus"),
    )
    runtime = _as_dict(runtime_raw)
    status_value = (
        runtime_raw if isinstance(runtime_raw, str) else _first_present(
            runtime.get("status"),
            runtime.get("state"),
            runtime.get("health"),
            runtime.get("availability"),
            hints.get("healthStatus"),
            "unknown",
        )
    )
    normalized_status = str(status_value or "unknown").strip().lower()
    current_load = _as_float(
        _first_present(
            runtime.get("currentLoad"),
            runtime.get("current_load"),
            runtime.get("activeTasks"),
            runtime.get("active_tasks"),
            hints.get("currentLoad"),
        )
    )
    max_concurrency = _as_float(
        _first_present(
            runtime.get("maxConcurrentTasks"),
            runtime.get("max_concurrent_tasks"),
            runtime.get("capacity"),
            hints.get("maxConcurrentTasks"),
        )
    )
    queue_depth = _as_float(_first_present(runtime.get("queueDepth"), runtime.get("queue_depth")))
    max_queue_depth = _as_float(_first_present(runtime.get("maxQueueDepth"), runtime.get("max_queue_depth")))
    accepting_tasks = _as_bool(
        _first_present(
            runtime.get("acceptingTasks"),
            runtime.get("accepting_tasks"),
            hints.get("acceptingTasks"),
        )
    )
    health_probe = _passport_runtime_health_probe(payload)
    health_blocks_dispatch = _runtime_health_blocks_dispatch()
    if health_probe.get("checked"):
        if health_probe.get("healthy"):
            normalized_status = "online"
        elif health_blocks_dispatch:
            normalized_status = "unhealthy"
            accepting_tasks = False
    rpc_probe = _passport_runtime_rpc_probe(payload, health_probe)
    if rpc_probe.get("checked") and not rpc_probe.get("ok"):
        normalized_status = "unhealthy"
        accepting_tasks = False

    reasons: List[str] = []
    if accepting_tasks is False:
        reasons.append("agent_not_accepting_tasks")
    if normalized_status in {
        "offline",
        "down",
        "unhealthy",
        "stopped",
        "disabled",
        "maintenance",
        "unavailable",
        "error",
    }:
        reasons.append(f"agent_runtime_{normalized_status}")
    if max_concurrency is not None and max_concurrency >= 0 and current_load is not None and current_load >= max_concurrency:
        reasons.append("agent_overloaded")
    if max_queue_depth is not None and max_queue_depth >= 0 and queue_depth is not None and queue_depth > max_queue_depth:
        reasons.append("agent_queue_full")
    if not health_probe.get("checked"):
        reasons.append("runtime_health_unverified")
    elif not health_probe.get("healthy") and health_blocks_dispatch:
        reasons.append("runtime_health_unhealthy")
    elif not health_probe.get("healthy"):
        reasons.append("runtime_health_unverified")
    if rpc_probe.get("checked") and rpc_probe.get("fallback"):
        reasons.append("runtime_rpc_fallback")
    elif rpc_probe.get("checked") and not rpc_probe.get("ok"):
        reasons.append("runtime_rpc_unavailable")
    elif health_probe.get("checked") and health_probe.get("healthy") and not rpc_probe.get("checked"):
        reasons.append("runtime_rpc_unverified")

    load_ratio = None
    if current_load is not None and max_concurrency and max_concurrency > 0:
        load_ratio = round(current_load / max_concurrency, 4)

    return {
        "status": normalized_status,
        "acceptingTasks": accepting_tasks is not False,
        "currentLoad": current_load,
        "maxConcurrentTasks": max_concurrency,
        "queueDepth": queue_depth,
        "maxQueueDepth": max_queue_depth,
        "loadRatio": load_ratio,
        "reasons": reasons,
        "healthProbe": health_probe,
        "rpcProbe": rpc_probe,
    }


def _passport_runtime_health_probe(payload: Dict[str, Any]) -> Dict[str, Any]:
    health_url = _passport_health_check_url(payload)
    if not health_url:
        return {"checked": False, "reason": "health_check_url_missing"}
    timeout = _runtime_health_timeout_seconds()
    checked_at = get_beijing_time().isoformat()
    try:
        response = requests.get(health_url, timeout=timeout)
        healthy = 200 <= response.status_code < 300
        return {
            "checked": True,
            "healthy": healthy,
            "url": health_url,
            "statusCode": response.status_code,
            "checkedAt": checked_at,
        }
    except requests.RequestException as exc:
        return {
            "checked": True,
            "healthy": False,
            "url": health_url,
            "error": type(exc).__name__,
            "message": str(exc)[:200],
            "checkedAt": checked_at,
        }


def _passport_runtime_rpc_probe(payload: Dict[str, Any], health_probe: Dict[str, Any]) -> Dict[str, Any]:
    if health_probe.get("checked") and not health_probe.get("healthy"):
        return {"checked": False, "reason": "health_probe_unhealthy"}
    if not health_probe.get("checked"):
        return {"checked": False, "reason": "health_probe_missing"}
    endpoint_url = _passport_primary_rpc_url(payload)
    if not endpoint_url:
        return {"checked": False, "reason": "rpc_endpoint_missing"}
    timeout = _runtime_rpc_timeout_seconds()
    checked_at = get_beijing_time().isoformat()
    probe_payload = {
        "jsonrpc": "2.0",
        "id": "registry-runtime-probe",
        "method": "rpc",
        "params": {
            "text": "registry runtime probe; reply with probe_ok",
            "task": "registry runtime probe",
            "command": {"text": "registry runtime probe"},
        },
    }
    try:
        response = requests.post(endpoint_url, json=probe_payload, timeout=timeout)
        parsed: Any = {}
        try:
            parsed = response.json()
        except ValueError:
            parsed = {}
        result = parsed.get("result") if isinstance(parsed, dict) else {}
        error = parsed.get("error") if isinstance(parsed, dict) else None
        fallback = bool(isinstance(result, dict) and result.get("fallback") is True)
        ok = 200 <= response.status_code < 300 and error is None and isinstance(result, dict) and not fallback
        return {
            "checked": True,
            "ok": ok,
            "fallback": fallback,
            "url": endpoint_url,
            "statusCode": response.status_code,
            "error": error,
            "checkedAt": checked_at,
        }
    except requests.RequestException as exc:
        return {
            "checked": True,
            "ok": False,
            "fallback": False,
            "url": endpoint_url,
            "error": type(exc).__name__,
            "message": str(exc)[:200],
            "checkedAt": checked_at,
        }


def _runtime_health_timeout_seconds() -> float:
    raw_value = os.getenv("REGISTRY_RUNTIME_HEALTH_TIMEOUT_SECONDS", "0.8")
    try:
        timeout = float(raw_value)
    except (TypeError, ValueError):
        return 0.8
    return max(0.1, min(timeout, 5.0))


def _runtime_rpc_timeout_seconds() -> float:
    raw_value = os.getenv("REGISTRY_RUNTIME_RPC_TIMEOUT_SECONDS", "1.2")
    try:
        timeout = float(raw_value)
    except (TypeError, ValueError):
        return 1.2
    return max(0.1, min(timeout, 5.0))


def _runtime_health_blocks_dispatch() -> bool:
    return os.getenv("REGISTRY_RUNTIME_HEALTH_REQUIRE_DISPATCH_BLOCK", "false").strip().lower() in {
        "1",
        "true",
        "yes",
        "on",
    }


def _passport_health_check_url(payload: Dict[str, Any]) -> Optional[str]:
    for endpoint in _passport_endpoint_dicts(payload):
        explicit_url = _first_present(
            endpoint.get("healthCheckUrl"),
            endpoint.get("healthCheckURL"),
            endpoint.get("healthUrl"),
            endpoint.get("healthURL"),
        )
        if explicit_url:
            return str(explicit_url)
        health_path = _first_present(
            endpoint.get("healthPath"),
            endpoint.get("healthCheckPath"),
        )
        if health_path:
            return _endpoint_url_with_path(str(endpoint.get("url") or ""), str(health_path))
    return None


def _passport_primary_rpc_url(payload: Dict[str, Any]) -> Optional[str]:
    for endpoint in _passport_endpoint_dicts(payload):
        endpoint_url = endpoint.get("url")
        if endpoint_url:
            return str(endpoint_url)
    return None


def _passport_endpoint_dicts(payload: Dict[str, Any]) -> List[Dict[str, Any]]:
    acp = _as_dict(payload.get("acp"))
    candidates = [
        acp.get("endpoints"),
        acp.get("endPoints"),
        payload.get("endpoints"),
        payload.get("endPoints"),
    ]
    endpoints: List[Dict[str, Any]] = []
    for candidate in candidates:
        if isinstance(candidate, list):
            endpoints.extend([item for item in candidate if isinstance(item, dict)])
    return endpoints


def _endpoint_url_with_path(endpoint_url: str, health_path: str) -> Optional[str]:
    parsed = urlparse(endpoint_url)
    if not parsed.scheme or not parsed.netloc:
        return None
    path = health_path if health_path.startswith("/") else f"/{health_path}"
    return urlunparse((parsed.scheme, parsed.netloc, path, "", "", ""))


def _passport_dispatch_reasons(
    agent: Agent, passport: AgentPassport, requester_user_id: Optional[str] = None
) -> List[str]:
    reasons: List[str] = []
    now = get_beijing_time()
    payload = passport.passport_payload or {}

    if not agent.is_active:
        reasons.append("agent_inactive")
    if agent.is_deleted:
        reasons.append("agent_deleted")
    if agent.is_disabled:
        reasons.append("agent_disabled")
    if agent.approval_status != ApprovalStatus.APPROVED:
        reasons.append("agent_not_approved")
    if passport.status != "VALID":
        reasons.append(f"passport_status_{passport.status.lower()}")
    if passport.decision != "APPROVE":
        reasons.append(f"review_decision_{passport.decision.lower()}")

    hints = _passport_orchestrator_hints(passport)
    if hints.get("eligibleForAutoDispatch") is False:
        reasons.append("orchestrator_auto_dispatch_not_allowed")
    reasons.extend(_passport_visibility_view(agent, payload, requester_user_id).get("reasons", []))
    non_blocking_runtime_reasons = {
        "runtime_health_unverified",
        "runtime_rpc_unverified",
    }
    reasons.extend(
        reason
        for reason in _passport_runtime_view(payload).get("reasons", [])
        if reason not in non_blocking_runtime_reasons
    )

    expires_at = _normalize_runtime_datetime(passport.expires_at)
    if expires_at and expires_at <= now:
        reasons.append("passport_expired")

    review_after = _normalize_runtime_datetime(passport.review_after)
    if review_after and review_after <= now:
        reasons.append("passport_review_due")

    runtime_review = payload.get("runtimeReview")
    if isinstance(runtime_review, dict) and runtime_review.get("status") == "REVIEW_DUE":
        reasons.append("runtime_review_due")

    return reasons


def build_passport_dispatch_view(
    agent: Agent, passport: AgentPassport, requester_user_id: Optional[str] = None
) -> Dict[str, Any]:
    hints = _passport_orchestrator_hints(passport)
    payload = passport.passport_payload or {}
    visibility = _passport_visibility_view(agent, payload, requester_user_id)
    runtime = _passport_runtime_view(payload)
    reasons = _passport_dispatch_reasons(agent, passport, requester_user_id)

    return {
        "agentAic": agent.aic,
        "agentId": str(agent.id),
        "passportId": passport.passport_id,
        "reviewId": passport.review_id,
        "status": passport.status,
        "eligibleForDispatch": len(reasons) == 0,
        "reasons": reasons,
        "decision": passport.decision,
        "riskLevel": passport.risk_level,
        "permissionTier": passport.permission_tier,
        "acsHash": passport.acs_hash,
        "acsVersion": passport.acs_version,
        "passportVersion": passport.passport_version,
        "issuedAt": passport.issued_at.isoformat() if passport.issued_at else None,
        "expiresAt": passport.expires_at.isoformat() if passport.expires_at else None,
        "reviewAfter": (
            passport.review_after.isoformat() if passport.review_after else None
        ),
        "orchestratorHints": hints,
        "visibility": visibility,
        "runtime": runtime,
        "permissions": payload.get("permissions", {}),
        "capabilities": payload.get("capabilities", {}),
        "acp": payload.get("acp", {}),
        "passport": payload,
    }


def build_discovery_passport_summary(
    agent: Agent, passport: AgentPassport, requester_user_id: Optional[str] = None
) -> Dict[str, Any]:
    payload = passport.passport_payload or {}
    identity = payload.get("identity") if isinstance(payload.get("identity"), dict) else {}
    capabilities = (
        payload.get("capabilities")
        if isinstance(payload.get("capabilities"), dict)
        else {}
    )
    visibility = _passport_visibility_view(agent, payload, requester_user_id)
    runtime = _passport_runtime_view(payload)
    dispatch_reasons = _passport_dispatch_reasons(agent, passport, requester_user_id)

    return {
        "agentAic": agent.aic,
        "agentId": str(agent.id),
        "name": identity.get("name") or agent.name,
        "version": identity.get("version") or agent.version,
        "passportId": passport.passport_id,
        "reviewId": passport.review_id,
        "status": passport.status,
        "decision": passport.decision,
        "riskLevel": passport.risk_level,
        "permissionTier": passport.permission_tier,
        "acsHash": passport.acs_hash,
        "acsVersion": passport.acs_version,
        "domains": capabilities.get("domains", []),
        "taskTypes": capabilities.get("taskTypes", []),
        "declaredSkills": capabilities.get("declaredSkills", []),
        "orchestratorHints": _passport_orchestrator_hints(passport),
        "visibility": visibility,
        "runtime": runtime,
        "eligibleForDispatch": len(dispatch_reasons) == 0,
        "dispatchReasons": dispatch_reasons,
        "acp": payload.get("acp", {}),
        "updatedAt": passport.updated_at.isoformat() if passport.updated_at else None,
    }


def list_discovery_passport_summaries(
    db: Session, limit: int = 100, requester_user_id: Optional[str] = None
) -> List[Dict[str, Any]]:
    rows = (
        db.query(Agent, AgentPassport)
        .join(AgentPassport, AgentPassport.agent_id == Agent.id)
        .filter(
            AgentPassport.status == "VALID",
            AgentPassport.decision == "APPROVE",
            Agent.approval_status == ApprovalStatus.APPROVED,
            Agent.aic.isnot(None),
            Agent.is_active == True,
            Agent.is_deleted == False,
            Agent.is_disabled == False,
        )
        .order_by(AgentPassport.updated_at.desc())
        .limit(max(limit * 5, limit))
        .all()
    )
    latest_rows_by_name: Dict[str, Tuple[Agent, AgentPassport]] = {}
    for agent, passport in rows:
        current = latest_rows_by_name.get(agent.name)
        if current is None or _is_newer_agent_version(agent, current[0]):
            latest_rows_by_name[agent.name] = (agent, passport)

    sorted_rows = sorted(
        latest_rows_by_name.values(),
        key=lambda row: row[1].updated_at.isoformat() if row[1].updated_at else "",
        reverse=True,
    )
    items: List[Dict[str, Any]] = []
    for agent, passport in sorted_rows:
        summary = build_discovery_passport_summary(agent, passport, requester_user_id)
        if not summary["dispatchReasons"]:
            items.append(summary)
        if len(items) >= limit:
            break
    return items


def _agent_endpoint_urls_from_acs(acs: Optional[Dict[str, Any]]) -> List[str]:
    if not isinstance(acs, dict):
        return []
    endpoints = acs.get("endPoints") or acs.get("endpoints") or []
    urls: List[str] = []
    for endpoint in endpoints:
        if isinstance(endpoint, dict) and endpoint.get("url"):
            urls.append(str(endpoint["url"]))
    return urls


def _normalize_runtime_datetime(value: Any) -> Optional[datetime]:
    if not value:
        return None
    if isinstance(value, datetime):
        parsed = value
    elif isinstance(value, str):
        try:
            parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
        except ValueError:
            return None
    else:
        return None
    if parsed.tzinfo is None:
        now = get_beijing_time()
        if now.tzinfo is not None:
            parsed = parsed.replace(tzinfo=now.tzinfo)
    return parsed


def _runtime_review_event(
    *,
    reason: str,
    severity: str,
    message: str,
    source: str,
    data: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    return {
        "reason": reason,
        "severity": severity,
        "message": message,
        "source": source,
        "data": data or {},
    }


def collect_passport_runtime_review_events(
    agent: Agent, passport: AgentPassport, now: Optional[datetime] = None
) -> List[Dict[str, Any]]:
    """Collect runtime review triggers for a Passport without mutating it."""
    now = now or get_beijing_time()
    events: List[Dict[str, Any]] = []
    payload = passport.passport_payload or {}
    certificate = (
        (payload.get("acp") or {}).get("certificate")
        if isinstance(payload.get("acp"), dict)
        else {}
    )
    if not isinstance(certificate, dict):
        certificate = {}

    if agent.acs_hash and passport.acs_hash and agent.acs_hash != passport.acs_hash:
        events.append(
            _runtime_review_event(
                reason="acs_hash_changed",
                severity="HIGH",
                message="Agent ACS hash changed after Passport issuance.",
                source="registry",
                data={
                    "passportAcsHash": passport.acs_hash,
                    "currentAcsHash": agent.acs_hash,
                },
            )
        )

    if agent.acs_version != passport.acs_version:
        events.append(
            _runtime_review_event(
                reason="acs_version_changed",
                severity="MEDIUM",
                message="Agent ACS version changed after Passport issuance.",
                source="registry",
                data={
                    "passportAcsVersion": passport.acs_version,
                    "currentAcsVersion": agent.acs_version,
                },
            )
        )

    passport_endpoint_urls = sorted(_extract_ca_endpoint_urls(payload))
    current_endpoint_urls = sorted(_agent_endpoint_urls_from_acs(agent.acs))
    if passport_endpoint_urls and current_endpoint_urls and (
        passport_endpoint_urls != current_endpoint_urls
    ):
        events.append(
            _runtime_review_event(
                reason="endpoint_changed",
                severity="HIGH",
                message="Agent endpoint set changed after Passport issuance.",
                source="registry",
                data={
                    "passportEndpoints": passport_endpoint_urls,
                    "currentEndpoints": current_endpoint_urls,
                },
            )
        )

    expires_at = _normalize_runtime_datetime(passport.expires_at)
    if expires_at and expires_at <= now:
        events.append(
            _runtime_review_event(
                reason="passport_expired",
                severity="CRITICAL",
                message="Passport has expired.",
                source="registry",
                data={"expiresAt": expires_at.isoformat()},
            )
        )

    review_after = _normalize_runtime_datetime(passport.review_after)
    if review_after and review_after <= now:
        events.append(
            _runtime_review_event(
                reason="passport_review_due",
                severity="MEDIUM",
                message="Passport review_after is due.",
                source="registry",
                data={"reviewAfter": review_after.isoformat()},
            )
        )

    renewal_window_days = int(
        certificate.get("renewalWindowDays")
        or settings.PASSPORT_CERT_RENEWAL_WINDOW_DAYS
    )
    cert_not_after = _normalize_runtime_datetime(certificate.get("notAfter"))
    if cert_not_after:
        if cert_not_after <= now:
            events.append(
                _runtime_review_event(
                    reason="certificate_expired",
                    severity="CRITICAL",
                    message="Agent certificate has expired.",
                    source="ca-server",
                    data={"notAfter": cert_not_after.isoformat()},
                )
            )
        elif cert_not_after <= now + timedelta(days=renewal_window_days):
            events.append(
                _runtime_review_event(
                    reason="certificate_renewal_due",
                    severity="MEDIUM",
                    message="Agent certificate is inside the renewal window.",
                    source="ca-server",
                    data={
                        "notAfter": cert_not_after.isoformat(),
                        "renewalWindowDays": renewal_window_days,
                    },
                )
            )

    for alert in certificate.get("runtimeAlerts") or []:
        if not isinstance(alert, dict):
            continue
        if alert.get("resolved") is True:
            continue
        events.append(
            _runtime_review_event(
                reason=str(alert.get("code") or "certificate_runtime_alert"),
                severity=str(alert.get("severity") or "MEDIUM").upper(),
                message=str(alert.get("message") or "CA Server runtime alert."),
                source="ca-server",
                data=alert,
            )
        )

    return events


def _runtime_review_has_blocking_event(events: List[Dict[str, Any]]) -> bool:
    return any(
        str(event.get("severity")).upper() in {"HIGH", "CRITICAL"}
        or event.get("reason") in {"passport_expired", "certificate_expired"}
        for event in events
    )


def apply_passport_runtime_review_events(
    passport: AgentPassport,
    events: List[Dict[str, Any]],
    evaluated_at: Optional[datetime] = None,
) -> None:
    evaluated_at = evaluated_at or get_beijing_time()
    payload = passport.passport_payload or {}
    runtime_review = payload.setdefault("runtimeReview", {})
    runtime_review.update(
        {
            "status": "REVIEW_DUE" if events else "CURRENT",
            "eventCount": len(events),
            "events": events,
            "blockingDispatch": _runtime_review_has_blocking_event(events),
            "lastEvaluatedAt": evaluated_at.isoformat(),
        }
    )
    if events:
        runtime_review["lastScheduledAt"] = evaluated_at.isoformat()

    hints = payload.setdefault("orchestratorHints", {})
    hints["runtimeReviewRequired"] = bool(events)
    if _runtime_review_has_blocking_event(events):
        hints["eligibleForAutoDispatch"] = False
        hints["dispatchBlockReason"] = "runtime_review_required"
    elif not events and hints.get("dispatchBlockReason") == "runtime_review_required":
        hints.pop("dispatchBlockReason", None)

    passport.passport_payload = payload
    passport.updated_at = evaluated_at


def run_passport_runtime_review_scheduler(
    db: Session, limit: int = 100, sync_certificates: bool = False
) -> Dict[str, Any]:
    """Evaluate Passport runtime review triggers and optionally sync CA renewals."""
    bounded_limit = max(1, min(limit, 500))
    now = get_beijing_time()
    rows = (
        db.query(Agent, AgentPassport)
        .join(AgentPassport, AgentPassport.agent_id == Agent.id)
        .order_by(AgentPassport.updated_at.desc())
        .limit(bounded_limit)
        .all()
    )

    items: List[Dict[str, Any]] = []
    alert_events: List[Dict[str, Any]] = []
    due_count = 0
    certificate_sync_count = 0

    for agent, passport in rows:
        initial_events = collect_passport_runtime_review_events(agent, passport, now)
        final_events = initial_events
        sync_action = None

        should_sync_certificate = (
            sync_certificates
            and passport.status == "VALID"
            and any(
                event.get("reason")
                in {
                    "certificate_renewal_due",
                    "certificate_expired",
                    "passport_review_due",
                }
                for event in initial_events
            )
        )
        if should_sync_certificate:
            sync_result = sync_passport_certificate_with_ca(agent, passport)
            sync_action = _get_ca_sync_field(sync_result, "action")
            _apply_certificate_sync_result(passport, sync_result)
            certificate_sync_count += 1
            final_events = collect_passport_runtime_review_events(agent, passport, now)

        if initial_events or sync_action:
            due_count += 1 if initial_events else 0
            apply_passport_runtime_review_events(passport, final_events, now)
            db.add(passport)
            alert_events.extend(final_events)
            items.append(
                {
                    "agentAic": agent.aic,
                    "agentId": str(agent.id),
                    "passportId": passport.passport_id,
                    "status": passport.status,
                    "initialEventCount": len(initial_events),
                    "eventCount": len(final_events),
                    "events": final_events,
                    "certificateSyncAction": sync_action,
                    "reviewAfter": (
                        passport.review_after.isoformat()
                        if passport.review_after
                        else None
                    ),
                    "expiresAt": (
                        passport.expires_at.isoformat() if passport.expires_at else None
                    ),
                }
            )

    if items:
        db.commit()

    return {
        "status": "completed",
        "checkedCount": len(rows),
        "dueCount": due_count,
        "updatedCount": len(items),
        "certificateSyncCount": certificate_sync_count,
        "alerts": alert_events,
        "items": items,
        "evaluatedAt": now.isoformat(),
    }


def generate_and_persist_agent_passport(
    db: Session, agent: Agent, review_record: AgentSupervisorReview
) -> AgentPassport:
    existing = get_agent_passport_by_review_id(db, review_record.review_id)
    passport = existing or AgentPassport(
        passport_id=_passport_id_for_review(review_record),
        agent_id=agent.id,
        review_id=review_record.review_id,
        status="DRAFT",
        passport_version="1.0",
        acs_hash=agent.acs_hash or "",
        acs_version=agent.acs_version,
        decision=review_record.decision,
        risk_level=review_record.risk_level,
        permission_tier=review_record.permission_tier,
        passport_payload=review_record.passport_draft or {},
    )
    previous_payload = passport.passport_payload or {}
    previous_acp = (
        previous_payload.get("acp") if isinstance(previous_payload.get("acp"), dict) else {}
    )
    previous_certificate = (
        previous_acp.get("certificate")
        if isinstance(previous_acp.get("certificate"), dict)
        else None
    )
    previous_expires_at = passport.expires_at
    _apply_passport_from_review(passport, agent, review_record)
    if _passport_certificate_sync_is_current(
        previous_certificate, passport.status, agent.aic
    ):
        _passport_certificate_payload(passport.passport_payload).update(previous_certificate)
        passport.expires_at = previous_expires_at
    else:
        sync_result = sync_passport_certificate_with_ca(agent, passport)
        _apply_certificate_sync_result(passport, sync_result)
    db.add(passport)
    db.commit()
    db.refresh(passport)
    return passport


def auto_publish_supervisor_approved_agent(db: Session, agent: Agent) -> Agent:
    if agent.approval_status != ApprovalStatus.APPROVED:
        now = get_beijing_time()
        agent.approval_status = ApprovalStatus.APPROVED
        agent.processed_at = now
        agent.process_comments = "Auto-published after Supervisor APPROVE and VALID Passport."
        agent.updated_at = now
        db.add(agent)
        db.commit()
        db.refresh(agent)

    if not agent.aic:
        generate_aic_for_agent(db, agent)

    return agent


def publish_agent_passport_after_manual_approval(
    db: Session,
    agent: Agent,
    processor_id: uuid.UUID,
    comments: Optional[str] = None,
) -> Optional[AgentPassport]:
    passport = get_latest_agent_passport(db, agent.id)
    if not passport:
        review_record = get_latest_supervisor_review(db, agent.id)
        if (
            not review_record
            or review_record.status != "COMPLETED"
            or not review_record.passport_draft
        ):
            review_result = run_and_persist_supervisor_review(db, agent)
            review_record = get_supervisor_review_by_review_id(
                db, agent.id, review_result["reviewId"]
            )
        if (
            not review_record
            or review_record.status != "COMPLETED"
            or not review_record.passport_draft
        ):
            logger.error(
                "Manual approval could not publish passport for agent %s: "
                "Supervisor review is missing or incomplete.",
                agent.id,
            )
            return None
        passport = generate_and_persist_agent_passport(db, agent, review_record)
    if passport.status == "VALID" and passport.decision == "APPROVE":
        return passport

    now = get_beijing_time()
    payload = copy.deepcopy(passport.passport_payload or {})
    payload["status"] = "VALID"
    payload["decision"] = "APPROVE"
    _sync_passport_identity_from_agent(payload, agent)

    review_evidence = payload.setdefault("reviewEvidence", {})
    if isinstance(review_evidence, dict):
        manual_review = review_evidence.setdefault("manualReview", {})
        if isinstance(manual_review, dict):
            manual_review.update(
                {
                    "required": False,
                    "status": "APPROVED",
                    "approvedBy": str(processor_id),
                    "approvedAt": now.isoformat(),
                    "comments": comments,
                }
            )

    verification = payload.setdefault("verification", {})
    if isinstance(verification, dict):
        verification["manualReviewRequired"] = False
        verification["manualReviewStatus"] = "APPROVED"

    hints = payload.setdefault("orchestratorHints", {})
    if isinstance(hints, dict):
        hints["eligibleForAutoDispatch"] = True
        hints["manualApprovalPassed"] = True

    passport.status = "VALID"
    passport.decision = "APPROVE"
    passport.passport_payload = payload
    passport.acs_hash = agent.acs_hash or ""
    passport.acs_version = agent.acs_version
    passport.issued_at = passport.issued_at or now
    passport.expires_at = None
    passport.review_after = None
    passport.updated_at = now

    sync_result = sync_passport_certificate_with_ca(agent, passport)
    _apply_certificate_sync_result(passport, sync_result)

    db.add(passport)
    db.commit()
    db.refresh(passport)
    return passport


def run_and_persist_supervisor_review(
    db: Session, agent: Agent
) -> Dict[str, Any]:
    existing = get_supervisor_review_for_agent_snapshot(db, agent)
    if existing and existing.review_result:
        return existing.review_result

    try:
        review_result = review_agent_submission(agent)
    except Exception as exc:
        review_record = existing or _build_failed_supervisor_review_record(agent, exc)
        _apply_failed_supervisor_review_result(review_record, exc)
        db.add(review_record)
        db.commit()
        db.refresh(review_record)
        raise

    review_record = existing or _build_supervisor_review_record(agent, review_result)
    _apply_supervisor_review_result(review_record, agent, review_result)
    db.add(review_record)
    db.commit()
    db.refresh(review_record)
    return review_record.review_result or review_result


def run_review_and_persist_passport(db: Session, agent: Agent) -> Dict[str, Any]:
    review_result = run_and_persist_supervisor_review(db, agent)
    review_record = get_supervisor_review_by_review_id(
        db, agent.id, review_result["reviewId"]
    )
    if review_record:
        if _passport_status_for_review(review_record) == "VALID":
            agent = auto_publish_supervisor_approved_agent(db, agent)
            _sync_review_snapshot_from_agent(review_record, agent)
            db.add(review_record)
            db.commit()
            db.refresh(review_record)
        generate_and_persist_agent_passport(db, agent, review_record)
        retired_agents = retire_older_same_name_agents(db, agent)
        if retired_agents:
            db.commit()
        return review_record.review_result or review_result
    return review_result


def cancel_agent_submission(
    db: Session, agent_id: uuid.UUID, user_id: uuid.UUID
) -> Agent:
    """Cancel a pending agent submission"""
    agent = get_agent(db, agent_id, raise_exception=True)

    # Ensure agent is active
    if not agent.is_active:
        raise AgentException(
            status_code=status.HTTP_400_BAD_REQUEST,
            error_name=AgentError.AGENT_INACTIVE,
            error_msg="Cannot update an inactive agent",
            input_params={"agent_id": str(agent_id)},
        )
    # Ensure user is the creator of the agent
    if agent.created_by_id != user_id:
        raise AgentException(
            status_code=status.HTTP_403_FORBIDDEN,
            error_name=AgentError.UNAUTHORIZED_ACCESS,
            error_msg="You can only cancel your own agent submissions",
            input_params={"agent_id": str(agent_id), "user_id": str(user_id)},
        )

    # Ensure agent is in pending status
    if agent.approval_status != ApprovalStatus.PENDING:
        raise AgentException(
            status_code=status.HTTP_400_BAD_REQUEST,
            error_name=AgentError.INVALID_STATUS_TRANSITION,
            error_msg="Only agents in pending status can be canceled",
            input_params={"agent_id": str(agent_id), "status": agent.approval_status},
        )

    # Update status back to draft - using Beijing time
    agent.approval_status = ApprovalStatus.DRAFT
    agent.submitted_at = None
    agent.updated_at = get_beijing_time()

    db.add(agent)
    db.commit()
    db.refresh(agent)

    return agent


