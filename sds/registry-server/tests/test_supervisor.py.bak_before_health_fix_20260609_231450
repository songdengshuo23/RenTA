# 直接在测试里构造一个 Agent ORM/Model 对象，避免依赖数据库或 submit API。
# 这里把状态设成 PENDING，是为了模拟“已经提交到 Registry，正准备进入 Supervisor 审查”的现场。
def _agent(acs, **overrides):
    now = get_beijing_time()
    data = {
        "id": uuid.uuid4(),
        "name": acs.get("name", "Supervisor Test Agent"),
        "version": acs.get("version", "1.0.0"),
        "description": acs.get("description"),
        "acs": acs,
        "acs_hash": sha256(str(acs)),
        "acs_version": 1,
        "created_by_id": uuid.uuid4(),
        "created_at": now,
        "updated_at": now,
        "submitted_at": now,
        "approval_status": ApprovalStatus.PENDING,
        "is_active": True,
        "is_deleted": False,
        "is_disabled": False,
        "is_ontology": False,
    }
    data.update(overrides)
    return Agent(**data)


# 从 review["checks"] 中按 checkId 找到单条规则结果。
# 这样断言时可以直指某条规则，不需要在测试里重复写筛选逻辑。
def _check(review, check_id):
    return next(item for item in review["checks"] if item["checkId"] == check_id)


