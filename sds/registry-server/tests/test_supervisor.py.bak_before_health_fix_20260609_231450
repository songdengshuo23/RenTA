def _runtime_passport(agent, *, review_after=None, cert_not_after=None):
    now = get_beijing_time()
    cert_not_after = cert_not_after or (now + timedelta(days=40))
    return AgentPassport(
        passport_id="passport_runtime_review",
        agent_id=agent.id,
        review_id="review_runtime_review",
        status="VALID",
        passport_version="1.0",
        acs_hash=agent.acs_hash or "",
        acs_version=agent.acs_version,
        decision="APPROVE",
        risk_level="LOW",
        permission_tier="T3",
        issued_at=now,
        expires_at=cert_not_after,
        review_after=review_after,
        passport_payload={
            "status": "VALID",
            "acp": {
                "endpoints": [{"url": "https://agent.example.com/rpc"}],
                "certificate": {
                    "status": "VALID",
                    "issuer": "CN=ACPS Test CA",
                    "serialNumber": "TEST-SERIAL-001",
                    "notBefore": now.isoformat(),
                    "notAfter": cert_not_after.isoformat(),
                    "renewalWindowDays": 14,
                    "runtimeAlerts": [],
                },
            },
            "orchestratorHints": {"eligibleForAutoDispatch": True},
        },
    )


def test_runtime_review_events_mark_passport_due_for_dispatch():
    now = get_beijing_time()
    agent = _agent(_base_acs())
    passport = _runtime_passport(
        agent,
        review_after=now - timedelta(minutes=1),
        cert_not_after=now + timedelta(days=3),
    )

    events = collect_passport_runtime_review_events(agent, passport, now)
    reasons = {event["reason"] for event in events}
    assert "passport_review_due" in reasons
    assert "certificate_renewal_due" in reasons

    apply_passport_runtime_review_events(passport, events, now)
    assert passport.passport_payload["runtimeReview"]["status"] == "REVIEW_DUE"
    assert passport.passport_payload["orchestratorHints"]["runtimeReviewRequired"] is True

    dispatch_view = build_passport_dispatch_view(agent, passport)
    assert dispatch_view["eligibleForDispatch"] is False
    assert "passport_review_due" in dispatch_view["reasons"]
    assert "runtime_review_due" in dispatch_view["reasons"]


def test_runtime_review_scheduler_can_trigger_certificate_sync(monkeypatch):
    now = get_beijing_time()
    db = _SupervisorReviewSession()
    agent = _agent(_base_acs())
    passport = _runtime_passport(
        agent,
        review_after=now - timedelta(minutes=1),
        cert_not_after=now + timedelta(days=2),
    )
    db.agents.append(agent)
    db.passports.append(passport)
    sync_calls = []

    def _sync(agent_arg, passport_arg):
        sync_calls.append((agent_arg, passport_arg))
        not_before = now.isoformat()
        not_after = (now + timedelta(days=49)).isoformat()
        next_review_after = (now + timedelta(days=35)).isoformat()
        return {
            "aic": agent_arg.aic or agent_arg.acs.get("aic"),
            "passportStatus": "VALID",
            "action": "renewed",
            "certificateStatus": "VALID",
            "issuer": "CN=ACPS Test CA",
            "serialNumber": "TEST-SERIAL-NEW",
            "notBefore": not_before,
            "notAfter": not_after,
            "version": 2,
            "revokedCertCount": 1,
            "revocationReason": "superseded",
            "mtlsRequired": True,
            "renewalWindowDays": 14,
            "daysUntilExpiry": 49,
            "renewalDue": False,
            "nextReviewAfter": next_review_after,
            "rotationAudit": [{"action": "certificate_rotated"}],
            "runtimeAlerts": [
                {
                    "code": "certificate_renewal_due",
                    "severity": "MEDIUM",
                    "resolved": True,
                }
            ],
        }

    monkeypatch.setattr(agent_service, "sync_passport_certificate_with_ca", _sync)

    result = run_passport_runtime_review_scheduler(
        db, limit=10, sync_certificates=True
    )

    assert len(sync_calls) == 1
    assert result["checkedCount"] == 1
    assert result["dueCount"] == 1
    assert result["certificateSyncCount"] == 1
    assert result["updatedCount"] == 1
    assert result["items"][0]["certificateSyncAction"] == "renewed"
    assert passport.passport_payload["acp"]["certificate"]["serialNumber"] == (
        "TEST-SERIAL-NEW"
    )
    assert passport.review_after > now
    assert passport.passport_payload["runtimeReview"]["status"] == "CURRENT"

