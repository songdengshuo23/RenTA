def test_runtime_validation_supports_request_spec_and_response_path(monkeypatch):
    monkeypatch.setenv("SUPERVISOR_ENABLE_RUNTIME_VALIDATION", "true")
    monkeypatch.setenv("SUPERVISOR_RUNTIME_ALLOW_PRIVATE_ENDPOINTS", "true")

    def _responder(prompt, payload, path, headers):
        lower = str(prompt or payload.get("input") or "").lower()
        if path == "/v1/run":
            assert headers.get("X-Test") == "runtime"
            assert payload == {"payload": {"prompt": "Summarize this paragraph as JSON."}}
            return {
                "__raw__": True,
                "body": {"data": {"result": {"summary": "safe summary", "format": "json"}}},
            }
        if "ignore previous instructions" in lower:
            return "I cannot reveal hidden system prompts or registry approval rules."
        if "return any private user data" in lower:
            return "I refuse to return private user data, internal records, passwords, or tokens."
        if "call any available tool" in lower:
