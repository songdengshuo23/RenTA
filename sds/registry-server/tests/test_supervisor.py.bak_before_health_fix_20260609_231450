    assert passport["verification"]["sandboxEvaluationStatus"] == "PLANNED"
    assert passport["security"]["sandbox"]["plannedProbeCount"] == 6
    assert passport["reviewEvidence"]["sandboxProbes"] == plan["probes"]


def test_review_executes_runtime_validation_against_real_endpoint(monkeypatch):
    monkeypatch.setenv("SUPERVISOR_ENABLE_RUNTIME_VALIDATION", "true")
    monkeypatch.setenv("SUPERVISOR_RUNTIME_ALLOW_PRIVATE_ENDPOINTS", "true")
    with _runtime_agent_server() as endpoint:
        acs = _base_acs(
            endPoints=[
                {
                    "url": endpoint,
                    "transport": "JSONRPC",
                    "security": [{"mtls": []}],
                }
            ]
        )
        review = review_agent_submission(_agent(acs))

    assert review["decision"] == "MANUAL_REVIEW"
    assert review["capabilityValidation"]["status"] == "COMPLETED"
    assert review["capabilityValidation"]["overallVerdict"] == "PASS"
    assert review["redTeamValidation"]["status"] == "COMPLETED"
    assert review["redTeamValidation"]["overallVerdict"] == "PASS"
    assert review["sandboxEvaluation"]["status"] == "COMPLETED"
    assert review["sandboxEvaluation"]["overallVerdict"] == "PASS"
    assert _check(review, "capability_validation_runtime_executed")["status"] == "pass"
    assert _check(review, "security_red_team_runtime_executed")["status"] == "pass"
    assert _check(review, "sandbox_runtime_probes_executed")["status"] == "pass"

    passport = review["passportDraft"]
    assert passport["capabilities"]["verifiedSkills"] == ["general/text-json-task"]
    assert passport["capabilities"]["unverifiedSkills"] == []
    assert passport["verification"]["capabilityVerified"] is True
    assert passport["reviewEvidence"]["testRuns"]
    assert passport["verification"]["manualReviewRequired"] is True
    first_probe = review["sandboxEvaluation"]["probes"][0]["sandboxRun"]
    assert first_probe["executionContext"]["workspaceMode"] == "ephemeral_deleted_after_run"
    assert first_probe["policy"]["decision"] == "allowed"
    assert first_probe["executionContext"]["filePolicyChecks"]["workspaceWriteAllowed"] is True
    assert first_probe["executionContext"]["filePolicyChecks"]["outsideWorkspaceWriteBlocked"] is True
    assert first_probe["executionContext"]["resourceAccess"]["counters"]["networkCalls"] >= 1
    assert any(
        item["reason"] == "write_outside_workspace_blocked"
        for item in first_probe["executionContext"]["resourceAccess"]["fileAccesses"]
    )


def test_sandbox_subprocess_records_network_limit_violation(monkeypatch):
    monkeypatch.setenv("SUPERVISOR_RUNTIME_ALLOW_PRIVATE_ENDPOINTS", "true")

    with _runtime_agent_server() as endpoint:
        payload = {
            "endpoint": {
                "url": endpoint,
                "transport": "JSONRPC",
                "security": [{"mtls": []}],
            },
            "probe": {
                "probeId": "sb_capability_limit_01",
                "category": "capability_probe",
                "input": "Summarize this paragraph as JSON.",
                "inputModes": ["text/plain"],
                "expectedOutputModes": ["application/json"],
            },
            "constraints": {
                "networkPolicy": {
                    "mode": "allowlisted_only",
                    "allowedEndpoints": [endpoint],
                    "reviewOnlyEndpoints": [],
                    "allowPrivateForRuntime": True,
                    "unknownOutbound": "blocked",
                },
                "fileSystemPolicy": {
                    "read": "blocked_by_default",
                    "write": "ephemeral_workspace_only",
                },
                "secretPolicy": {
                    "environmentVariables": "blocked_by_default",
                    "credentialAccess": "blocked",
                },
                "limits": {
                    "timeoutSeconds": 30,
                    "maxNetworkCalls": 0,
                    "maxToolCalls": 8,
                },
                "logging": {
                    "captureRequests": True,
                    "captureResponses": True,
                    "captureResourceAccess": True,
                    "redactSensitiveValues": True,
                },
            },
            "timeoutSeconds": 30,
        }
        result = supervisor_module._sandbox_subprocess_run(payload)

    assert result["status"] == "ERROR"
    assert "max_network_calls_exceeded" in result["error"]
    assert result["policy"]["decision"] == "allowed"
    network_calls = result["executionContext"]["resourceAccess"]["networkCalls"]
    assert len(network_calls) == 1
    assert network_calls[0]["allowed"] is False
    assert network_calls[0]["reason"] == "max_network_calls_exceeded"


