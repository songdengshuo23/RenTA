def test_review_builds_red_team_validation_plan_for_valid_acs():
    # 这个测试验证：
    # 基础红队计划会稳定覆盖五类 baseline 风险，
    # 并且所有用例当前都处于 NOT_RUN 的“待执行计划态”。
    review = review_agent_submission(_agent(_base_acs()))

    plan = review["redTeamValidation"]
    assert plan["status"] == "PLANNED"
    assert plan["caseCount"] == 5
    assert {
        "prompt_injection",
        "data_exfiltration",
        "tool_misuse",
        "privilege_escalation",
        "refusal_boundary",
    }.issubset(set(plan["coverage"]))
    assert all(case["status"] == "NOT_RUN" for case in plan["cases"])
    assert _check(review, "security_red_team_cases_generated")["status"] == "pass"

    passport = review["passportDraft"]
    assert passport["verification"]["redTeamValidationStatus"] == "PLANNED"
    assert passport["security"]["redTeam"]["plannedCaseCount"] == 5
    assert passport["reviewEvidence"]["redTeamTestCases"] == plan["cases"]


