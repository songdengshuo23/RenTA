class _SupervisorReviewQuery:
    def __init__(self, rows):
        self.rows = rows

    def filter(self, *args):
        return self

    def options(self, *args):
        return self

    def order_by(self, *args):
        return self

    def first(self):
        return self.rows[0] if self.rows else None


class _RuntimePassportQuery:
    def __init__(self, rows):
        self.rows = rows
        self._limit = None

    def join(self, *args):
        return self

    def filter(self, *args):
        return self

    def order_by(self, *args):
        return self

    def limit(self, value):
        self._limit = value
        return self

    def all(self):
        if self._limit is None:
            return self.rows
        return self.rows[: self._limit]


class _SupervisorReviewSession:
    def __init__(self):
        self.agents = []
        self.users = []
        self.records = []
        self.passports = []
        self.change_logs = []
        self.commit_count = 0
        self._seq = 0

    def query(self, *models):
        if models == (Agent,):
            return _SupervisorReviewQuery(self.agents)
        if models == (User,):
            return _SupervisorReviewQuery(self.users)
        if models == (AgentSupervisorReview,):
            return _SupervisorReviewQuery(self.records)
        if models == (AgentPassport,):
            return _SupervisorReviewQuery(self.passports)
        if models == (Agent, AgentPassport):
            rows = []
            for passport in self.passports:
                agent = next(
                    (item for item in self.agents if item.id == passport.agent_id),
                    None,
                )
                if agent:
                    rows.append((agent, passport))
            return _RuntimePassportQuery(rows)
        raise AssertionError(f"unexpected model(s): {models}")

    def add(self, record):
        if isinstance(record, Agent):
            if record not in self.agents:
                self.agents.append(record)
            return
        if isinstance(record, User):
            if record not in self.users:
                self.users.append(record)
            return
        if isinstance(record, AgentSupervisorReview):
            if record not in self.records:
                self.records.append(record)
            return
        if isinstance(record, AgentPassport):
            if record not in self.passports:
                self.passports.append(record)
            return
        if record.__class__.__name__ == "ChangeLog":
            self.change_logs.append(record)
            return
        raise AssertionError(f"unexpected record: {record}")

    def execute(self, *args, **kwargs):
        self._seq += 1

        class _Result:
            def __init__(self, value):
                self.value = value

            def scalar(self):
                return self.value

        return _Result(self._seq)

    def commit(self):
        self.commit_count += 1

    def refresh(self, record):
        return None


