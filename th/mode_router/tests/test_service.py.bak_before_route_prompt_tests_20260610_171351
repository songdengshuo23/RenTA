        self.assertIn("plan", response["zh"])

    def test_orchestrator_execute_runs_group_chat_when_mode2(self):
        class FakeTaskState:
            AwaitingCompletion = "awaiting-completion"
            Completed = "completed"
            Failed = "failed"
            Rejected = "rejected"
            Canceled = "canceled"

        class FakeACSObject:
            def __init__(self, aic):
                self.aic = aic

        class FakeLeaderMqClient:
            def __init__(self, session):
                self.session = session

            async def start_task(self, session_id, text_content, task_id, mentions):
                self.session.started.append({"session_id": session_id, "task_id": task_id, "mentions": mentions, "prompt": text_content})
                self.session.snapshots[(task_id, mentions[0])] = {
                    "state": FakeTaskState.AwaitingCompletion,
                    "product_text": f"result-for-{mentions[0]}",
                }

            async def complete_task(self, task_id, session_id, mentions):
                self.session.completed.append({"task_id": task_id, "mentions": mentions})

        class FakeGroupSession:
            def __init__(self):
                self.started = []
                self.completed = []
                self.snapshots = {}
                self.leader_mq_client = FakeLeaderMqClient(self)

            def get_partner_task_snapshot(self, task_id, aic):
                return self.snapshots.get((task_id, aic))

        class FakeGroupLeader:
            last_session = None
            invited = []

            def __init__(self, leader_aic, rabbitmq_config):
                self.leader_aic = leader_aic
                self.rabbitmq_config = rabbitmq_config

            async def create_group_session(self, session_id, initial_partners):
                self.session = FakeGroupSession()
                FakeGroupLeader.last_session = self.session
                return self.session

            async def invite_partner(self, session_id, partner_acs, partner_rpc_url):
                FakeGroupLeader.invited.append((partner_acs.aic, partner_rpc_url))

        fake_aip = types.ModuleType("acps_sdk.aip")
        fake_aip.GroupLeader = FakeGroupLeader
        fake_aip.ACSObject = FakeACSObject
        fake_aip.TaskState = FakeTaskState
        fake_sdk = types.ModuleType("acps_sdk")
        fake_sdk.aip = fake_aip
        old_modules = {name: sys.modules.get(name) for name in ("acps_sdk", "acps_sdk.aip")}
        sys.modules["acps_sdk"] = fake_sdk
        sys.modules["acps_sdk.aip"] = fake_aip
        try:
            response = self._post_json(
                "/orchestrator/execute",
                {
                    "task": "设计一个需要市场和法务协作的方案",
                    "save_report": False,
                    "route_scores": {"LLM": 0.01, "Agent": 0.1, "多Agent": 0.95},
                    "hints": {"estimated_skill_count": 2, "requires_independent_roles": True, "parallelizable": True},
                    "skills": [
                        {
                            "aic": "agent-market",
                            "agent_name": "Market Agent",
                            "skillid": "market-entry",
                            "score": 0.95,
                            "acs": {"endPoints": [{"url": "http://127.0.0.1:8021/agents/market/rpc"}]},
                        },
                        {
                            "aic": "agent-legal",
                            "agent_name": "Legal Agent",
                            "skillid": "compliance",
                            "score": 0.94,
                            "acs": {"endPoints": [{"url": "http://127.0.0.1:8022/agents/legal/rpc"}]},
                        },
                    ],
                },
            )
        finally:
            for name, module in old_modules.items():
                if module is None:
                    sys.modules.pop(name, None)
                else:
                    sys.modules[name] = module

        self.assertEqual(response["decision"]["mode"], "mode_2")
        self.assertFalse(response["execution"]["dry_run"])
        self.assertTrue(response["execution"]["group_chat"])
        self.assertEqual(response["execution"]["status"], "done")
        self.assertEqual(len(response["execution"]["runs"]), 2)
        self.assertEqual(len(FakeGroupLeader.last_session.started), 2)
        self.assertIn(("agent-market", "http://127.0.0.1:8021/group/rpc"), FakeGroupLeader.invited)


if __name__ == "__main__":
    unittest.main()
