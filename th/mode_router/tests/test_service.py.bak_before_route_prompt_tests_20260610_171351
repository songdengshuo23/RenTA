                            "agent-legal": {"name": "Legal Agent"}
                        },
                        "agents": [
                            {
                                "group": "default",
                                "agentSkills": [
                                    {"aic": "agent-market", "skillId": "market-entry", "ranking": 1, "memo": "enhanced_score=0.92"},
                                    {"aic": "agent-legal", "skillId": "compliance", "ranking": 2, "memo": "enhanced_score=0.91"}
