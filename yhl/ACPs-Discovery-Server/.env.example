# ==================== App 基本设置 ====================
APP_NAME="Agent Discovery Server"
APP_VERSION="1.0.0"
APP_DESC="基于自然语言请求提供 Agent 发现的 API 服务"
APP_LOG_LEVEL="info"

# ==================== Uvicorn 启动参数 ====================
UVICORN_HOST="0.0.0.0"
UVICORN_PORT=8005
UVICORN_RELOAD=false
UVICORN_LOG_LEVEL="info"

# ==================== Database 参数 ====================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_discovery
DATABASE_OUTPUT_SQL=false

# ==================== Registry 数据同步参数 ====================
DRC_BASE_URL="http://localhost:8001/acps-dsp-v2"
DRC_SERVICE_TOKEN=local-dsp-token
DRC_SNAPSHOT_CHUNK_SIZE=10000
DRC_CHANGES_CHUNK_SIZE=1000
DRC_CHANGES_PULL_INTERVAL=600
REGISTRY_ATR_BASE_URL="http://localhost:8001/acps-atr-v2"
REGISTRY_ATR_SERVICE_TOKEN=local-dev-token
# DRC WebHook配置
DRC_WEBHOOK_SECRET=drc_webhook_secret
DRC_WEBHOOK_RECEIVE_URL=http://localhost:8005/admin/drc/webhooks/receive

# ==================== LLM 模型配置（智谱 AI / 中转站） ====================
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
LLM_MODEL_NAME=GLM-4.7-Flash

# ==================== Embedding 模型配置（中转站兼容接口） ====================
OPENAI_BASE_URL=https://your-api.com/v1
OPENAI_API_KEY=your_api_key_here
EMBEDDING_MODEL_NAME=qwen3-embedding-8b
