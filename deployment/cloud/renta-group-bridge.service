[Unit]
Description=RenTA travel group bridge
After=network-online.target rabbitmq-server.service renta-mq-auth.service
Wants=network-online.target renta-mq-auth.service

[Service]
Type=simple
User=renta
Group=renta
WorkingDirectory=/opt/renta/th/mode_router
EnvironmentFile=/opt/renta/runtime/mode-router/.env
Environment=PYTHONDONTWRITEBYTECODE=1
Environment=PYTHONPATH=/opt/renta/th/mode_router:/opt/renta/ACPs_update_code/ACPs-SDK
ExecStart=/opt/renta/venv/mode-router/bin/python -B -u -m uvicorn travel_group_bridge:app --host 127.0.0.1 --port 8098
Restart=on-failure
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=renta.target
